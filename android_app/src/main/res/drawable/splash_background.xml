<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Fondo azul -->
    <item>
        <shape>
            <solid android:color="#1A5D8F" />
        </shape>
    </item>
    
    <!-- Círculo blanco central -->
    <item
        android:gravity="center"
        android:top="20dp"
        android:bottom="20dp">
        <shape>
            <solid android:color="#FFFFFF" />
            <corners android:radius="60dp" />
        </shape>
    </item>
    
    <!-- Icono del gato (se reutiliza el foreground) -->
    <item
        android:drawable="@drawable/ic_launcher_foreground"
        android:gravity="center" />
    
    <!-- Texto "Yozora Store" en la parte inferior -->
    <item android:gravity="bottom|center_horizontal" android:bottom="60dp">
        <shape>
            <solid android:color="#00000000" />
        </shape>
    </item>

</layer-list>